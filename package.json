{
  "name": "service-plane",
  "version": "0.2.0",
  "description": "Opinionated Cap'n Web service-plane primitives for object-capability RPC, STS capability tokens, scope-gated methods, and control-plane brokering.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JUVOJustin/service-plane.git"
  },
  "bugs": {
    "url": "https://github.com/JUVOJustin/service-plane/issues"
  },
  "homepage": "https://github.com/JUVOJustin/service-plane#readme",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "docs",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./service": {
      "types": "./dist/service/index.d.ts",
      "import": "./dist/service/index.js"
    },
    "./control-plane": {
      "types": "./dist/control-plane/index.d.ts",
      "import": "./dist/control-plane/index.js"
    },
    "./secrets": {
      "types": "./dist/shared/secrets.d.ts",
      "import": "./dist/shared/secrets.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "capnweb",
    "cap-n-web",
    "rpc",
    "object-capability",
    "microservices",
    "control-plane",
    "sts",
    "capabilities",
    "cloudflare-workers"
  ],
  "dependencies": {
    "capnweb": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.0.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18.14.1"
  }
}
